#!/usr/bin/env bash
#MISE description="Plan Terraform changes (infra/)"
#USAGE flag "--target <target>" help="Terraform target to plan"
#USAGE flag "--lock" default="false" help="Lock the state file during plan operation"
#USAGE flag "--var-file <file>" default="production.tfvars" help="Terraform variables file"

set -ex

cd "${MISE_PROJECT_ROOT}/infra"

TARGET="$usage_target"
LOCK="$usage_lock"
VAR_FILE="$usage_var_file"

TERRAFORM_CLI_ARGS="-lock=$LOCK"

if [ -n "$TARGET" ]; then
  TERRAFORM_CLI_ARGS="$TERRAFORM_CLI_ARGS -target $TARGET"
fi

if [ -f "$VAR_FILE" ]; then
  TERRAFORM_CLI_ARGS="$TERRAFORM_CLI_ARGS -var-file=$VAR_FILE"
fi

terraform plan $TERRAFORM_CLI_ARGS
