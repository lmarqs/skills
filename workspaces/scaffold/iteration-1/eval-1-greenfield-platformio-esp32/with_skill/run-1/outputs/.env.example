# Copy to .env.yaml and fill in machine-specific values.
# mise auto-loads .env.yaml (see mise.toml [env]._.file).

# Serial port for flashing/monitoring. Leave unset to let PlatformIO auto-detect.
# Example (Linux): PIO_UPLOAD_PORT: /dev/ttyUSB0
# Example (macOS): PIO_UPLOAD_PORT: /dev/cu.usbserial-0001
PIO_UPLOAD_PORT: ""
