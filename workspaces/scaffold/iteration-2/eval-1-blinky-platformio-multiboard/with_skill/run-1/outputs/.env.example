# Copy to .env.yaml and adjust. .env.yaml is gitignored.

# Default PlatformIO environment (board) when a task is run without an arg.
# One of: esp01s, esp32
PIO_DEFAULT_ENV: esp01s

# Default serial port for upload/monitor when --port is not passed.
PIO_PORT: /dev/ttyUSB0

# Serial monitor baud rate.
PIO_MONITOR_SPEED: "115200"
