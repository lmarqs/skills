# Copy to .env.yaml and adjust for your machine. mise auto-loads .env.yaml.
# Board-specific values are parameterized here so the task scripts stay generic.

# Fully-qualified board name for the Digispark (ATtiny85). `digispark-tiny` is the
# default 16.5 MHz Digispark. Other variants: digispark-pro, digispark-tiny16,
# digispark-tiny8, digispark-pro32, digispark-pro64.
ARDUINO_FQBN: "digistump:avr:digispark-tiny"

# The boards-manager core to install (passed to `arduino-cli core install`).
ARDUINO_FQBN_CORE: "digistump:avr"

# Third-party boards-manager index URL providing the Digistump AVR core.
# (Drazzy's mirror is the maintained replacement for the dead digistump.com index.)
ARDUINO_BOARD_MANAGER_URL: "http://drazzy.com/package_drazzy.com_index.json"

# Space-separated arduino-cli library names to install in `arduino:setup`.
# Leave empty if the sketch needs no external libraries.
ARDUINO_LIBS: ""

# Optional serial port for non-micronucleus uploads. The Digispark uses the
# micronucleus USB bootloader (portless: plug the board in when prompted), so this
# is normally left blank for a stock Digispark.
ARDUINO_PORT: ""
