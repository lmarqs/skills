# Copy to .env.yaml and fill in. mise auto-loads .env.yaml via [env] _.file.
# Real values live in .env.yaml (gitignored); never commit them.

# --- AWS (the build step reads a config value from AWS) ---
AWS_REGION: us-east-1
# Name of the SSM parameter holding the build-time config value.
AWS_CONFIG_PARAMETER: /cloudflare-worker/build-config

# --- Cloudflare (wrangler) ---
# Prefer `wrangler login`; or supply a scoped API token for CI:
# CLOUDFLARE_API_TOKEN: ""
# CLOUDFLARE_ACCOUNT_ID: ""
