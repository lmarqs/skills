# Copy to .env.yaml and fill in. .env.yaml is gitignored — never commit real values.
# Private npm dependencies are served from AWS CodeArtifact. node:setup authenticates
# to it automatically when CODEARTIFACT_DOMAIN is set below.

# --- AWS ---
AWS_REGION: us-east-1

# --- AWS CodeArtifact (private npm registry) ---
# Leave CODEARTIFACT_DOMAIN empty/unset to install from the public registry only.
CODEARTIFACT_DOMAIN: acme            # CodeArtifact domain name
CODEARTIFACT_OWNER: "111122223333"   # 12-digit AWS account id that owns the domain
CODEARTIFACT_REPO: shared            # CodeArtifact repository name
# Registry host npm authenticates against, e.g. acme-111122223333.d.codeartifact.us-east-1.amazonaws.com
NPM_REGISTRY_HOST: acme-111122223333.d.codeartifact.us-east-1.amazonaws.com

# --- LocalStack ---
AWS_ENDPOINT_URL: http://localhost:4566
