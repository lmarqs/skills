# Copy to .env.yaml and fill in. .env.yaml is gitignored.
#
# Private npm dependencies are served from AWS CodeArtifact. The node:setup task
# mints a short-lived CodeArtifact auth token (via aws-auth) when these are set.
AWS_REGION: us-east-1
CODEARTIFACT_DOMAIN: acme            # your CodeArtifact domain
CODEARTIFACT_OWNER: "111111111111"   # the AWS account id that owns the domain
# Registry host npm/pnpm authenticates against (no scheme), e.g.
#   <domain>-<owner>.d.codeartifact.<region>.amazonaws.com
NPM_REGISTRY_HOST: acme-111111111111.d.codeartifact.us-east-1.amazonaws.com

# LocalStack endpoint for local AWS emulation (docker compose service "localstack").
AWS_ENDPOINT_URL: http://localhost:4566
